@model Esfa.Recruit.Provider.Web.ViewModels.ApplicationReviews.ApplicationReviewsFeedbackViewModel
@{
    ViewBag.GaData.Vpv = "/recruitment/provider/page-application-reviews-to-unsuccessful-feedback";
    ViewBag.Title = "Give feedback (single and multiple applications)";
    var applicantsText = Model.IsMultipleApplications ? "applicants" : "applicant";
}
@section BackLink {
    <a asp-route="@RouteNames.ApplicationReviewsToUnsuccessful_Get" asp-all-route-data="@Model.RouteDictionary" esfa-automation="link-back" class="govuk-back-link">Back</a>
}
<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <partial name="@PartialNames.ValidationSummary" model="@(new ValidationSummaryViewModel { ModelState = ViewData.ModelState})" />
        <div>
            <h1 class="govuk-heading-xl govuk-!-margin-bottom-6">
                Give feedback to the unsuccessful @applicantsText
            </h1>
            <p class="govuk-body">
                A standard message will be emailed to the selected @applicantsText. You can edit this message before sending.
                <br />
                We will include links to support and other apprenticeships in the email.
            </p>
            <govuk-inset>
                @foreach (var applicant in Model.ApplicationsToUnsuccessful)
                {
                    <div>
                        @applicant.CandidateName : @applicant.GetFriendlyId()
                    </div>
                }
            </govuk-inset>
        </div>
        <form asp-route="@RouteNames.ApplicationReviewsToUnsuccessfulFeedback_Post" asp-route-ukprn="@Model.Ukprn" asp-route-vacancyId="@Model.VacancyId">
            @for (var i = 0; i < Model.ApplicationsToUnsuccessful.Count; i++)
            {
                <div class="govuk-!-display-none govuk-!-margin-bottom-0">
                    @Html.EditorFor(x => x.ApplicationsToUnsuccessful[i])
                </div>
            }
            <div esfa-validation-marker-for="CandidateFeedback" id="Multiple-unsuccessful-candidate-feedback" class="govuk-form-group">
                <div class="govuk-character-count" id="provider-character-count" data-module="govuk-character-count" data-maxwords="200">
                    <span esfa-validation-message-for="CandidateFeedback" class="govuk-error-message"></span>
                    <span class="govuk-label govuk-!-font-weight-bold">Your message to the @applicantsText</span>
                    <textarea asp-for="CandidateFeedback" class="govuk-textarea govuk-js-character-count" id="provider-multiple-candidate-feedback" name="CandidateFeedback" rows="6"></textarea>
                    <div id="provider-multiple-candidate-feedback-info" class="govuk-hint govuk-character-count__message">
                        You have 200 words remaining
                    </div>
                </div>
            </div>
            <div class="govuk-warning-text">
                <span class="govuk-warning-text__icon" aria-hidden="true">!</span>
                <strong class="govuk-warning-text__text">
                    Feedback will be sent to the @applicantsText. This cannot be undone.
                </strong>
            </div>
            <div id="provider-multiple-candidate-feedback-confirm" class="govuk-button-group">
                <input type="submit" value="Submit" class="govuk-button" />
                <a asp-route="@RouteNames.ApplicationReviewsToUnsuccessful_Get" asp-all-route-data="@Model.RouteDictionary" class="govuk-link govuk-link--no-visited-state">Cancel</a>
            </div>
        </form>
    </div>
</div>