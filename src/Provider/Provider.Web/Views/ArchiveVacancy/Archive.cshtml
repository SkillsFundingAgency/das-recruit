@model Esfa.Recruit.Provider.Web.ViewModels.ArchiveVacancy.ArchiveViewModel
@{
    ViewBag.Title = "Confirm archive vacancy";
}
@section BackLink
{
    <a asp-route="@RouteNames.VacancyManage_Get" asp-route-vacancyId="@Model.VacancyId" asp-route-ukprn="@Model.Ukprn" esfa-automation="link-back" class="govuk-back-link">Back</a>
}
<div class="govuk-grid-row">
    <div class="govuk-grid-column-one-half">
        <partial name="@PartialNames.ValidationSummary" model="new ValidationSummaryViewModel { ModelState = ViewData.ModelState }" />
        <h1 class="govuk-heading-l">Do you want to archive this vacancy?</h1>
    </div>
</div>
<div class="govuk-grid-row">
    <div class="govuk-grid-column-two-thirds">
        <div class="govuk-body govuk-!-margin-bottom-5">
            <p>You've responded to every applicant and can archive this vacancy.</p>
        </div>
        <div class="das-pane">
            <h3 class="govuk-heading-s">@Model.Title</h3>
            <div class="govuk-!-margin-bottom-3">
                <p class="govuk-body-s das-!-color-dark-grey">@Model.EmployerName</p>
            </div>
            <div class="govuk-!-margin-bottom-3">
                <p class="govuk-body-s das-!-color-dark-grey">Vacancy reference: @Model.VacancyReferenceDisplay</p>
            </div>
        </div>
        <div class="govuk-inset-text">
            This vacancy will be moved from closed to archived. You can clone an archived vacancy to list it again.
        </div>
        <form asp-route="@RouteNames.ArchiveVacancy_Post" asp-route-ukprn="@Model.Ukprn" asp-route-vacancyId="@Model.VacancyId">
            <input type="hidden" name="Status" value="@Model.Status"/>
            <div esfa-validation-marker-for="ConfirmArchive" class="govuk-form-group">
                <fieldset class="govuk-fieldset">
                    <span esfa-validation-message-for="ConfirmArchive" class="govuk-error-message"></span>
                    <div class="govuk-radios">
                        <div class="govuk-radios__item">
                            <input asp-for="@Model.ConfirmArchive" type="radio" value="true" class="govuk-radios__input" id="archive-yes"/>
                            <label class="govuk-label govuk-radios__label" for="archive-yes">Yes, archive this vacancy</label>
                        </div>
                        <div class="govuk-radios__item">
                            <input asp-for="@Model.ConfirmArchive" type="radio" value="false" class="govuk-radios__input" id="archive-no"/>
                            <label class="govuk-label govuk-radios__label" for="archive-no">No, I want to archive this later</label>
                        </div>
                    </div>
                </fieldset>
            </div>
            <div class="govuk-form-group">
                <input type="submit" value="Submit" class="govuk-button"/>
            </div>
        </form>
    </div>
</div>